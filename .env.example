# Keycloak realm URL (requires Keycloak 26.6.0+ with DCR enabled on the realm)
KEYCLOAK_REALM_URL=http://localhost:8080/realms/master

# Public base URL of this MCP server (used in OAuth discovery metadata)
FASTMCP_BASE_URL=http://localhost:3000

# Optional: comma-separated list of OAuth scopes tokens must carry (e.g. openid,profile)
# REQUIRED_SCOPES=

# Optional (recommended for production): token audience claim must match this value
# OIDC_AUDIENCE=http://localhost:3000
